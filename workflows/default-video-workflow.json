{
  "input": {
    "workflow": {
      "1": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {
          "ckpt_name": "__CHECKPOINT_NAME__"
        }
      },
      "2": {
        "class_type": "CLIPTextEncode",
        "inputs": {
          "text": "__VIDEO_PROMPT__",
          "clip": ["1", 1]
        }
      },
      "3": {
        "class_type": "CLIPTextEncode",
        "inputs": {
          "text": "__NEGATIVE_PROMPT__",
          "clip": ["1", 1]
        }
      },
      "4": {
        "class_type": "EmptyLatentImage",
        "inputs": {
          "width": "__VIDEO_WIDTH__",
          "height": "__VIDEO_HEIGHT__",
          "batch_size": "__VIDEO_FRAMES__"
        }
      },
      "5": {
        "class_type": "AnimateDiffLoader",
        "inputs": {
          "model": ["1", 0],
          "motion_module": "__MOTION_MODULE__"
        }
      },
      "6": {
        "class_type": "AnimateDiffSampler",
        "inputs": {
          "model": ["5", 0],
          "positive": ["2", 0],
          "negative": ["3", 0],
          "latent_image": ["4", 0],
          "seed": "__SEED__",
          "steps": "__STEPS__",
          "cfg": "__CFG__",
          "sampler_name": "__SAMPLER_NAME__",
          "scheduler": "__SCHEDULER__"
        }
      },
      "7": {
        "class_type": "VAEDecode",
        "inputs": {
          "samples": ["6", 0],
          "vae": ["1", 2]
        }
      },
      "8": {
        "class_type": "VideoCombine",
        "inputs": {
          "images": ["7", 0],
          "fps": "__VIDEO_FPS__",
          "format": "mp4"
        }
      }
    }
  }
}